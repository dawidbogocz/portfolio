@inject ThemeService ThemeService
@inject IJSRuntime JS

<nav class="navbar">
    <div class="nav-brand">dzeyd.dev</div>
    <div class="nav-links">
        <a class="nav-link" href="#about" @onclick:preventDefault @onclick='() => ScrollTo("about")'>About</a>
        <a class="nav-link" href="#experience" @onclick:preventDefault @onclick='() => ScrollTo("experience")'>Experience</a>
        <a class="nav-link" href="#projects" @onclick:preventDefault @onclick='() => ScrollTo("projects")'>Projects</a>
        <a class="nav-link" href="#games" @onclick:preventDefault @onclick='() => ScrollTo("games")'>Games</a>
        <a class="nav-link" href="#contact" @onclick:preventDefault @onclick='() => ScrollTo("contact")'>Contact</a>
    </div>
    <div class="theme-toggles">
        <button class="theme-dot@(ThemeService.CurrentTheme == "vsdark" ? " active" : "") vsdark-dot"
                @onclick='() => SetTheme("vsdark")'
                title="VS Dark"></button>
        <button class="theme-dot@(ThemeService.CurrentTheme == "godot" ? " active" : "") godot-dot"
                @onclick='() => SetTheme("godot")'
                title="Godot"></button>
        <button class="theme-dot@(ThemeService.CurrentTheme == "monokai" ? " active" : "") monokai-dot"
                @onclick='() => SetTheme("monokai")'
                title="Monokai"></button>
        <button class="theme-dot@(ThemeService.CurrentTheme == "light" ? " active" : "") light-dot"
                @onclick='() => SetTheme("light")'
                title="Light"></button>
    </div>
</nav>

@code {
    private async Task ScrollTo(string id)
    {
        await JS.InvokeVoidAsync("portfolio.scrollTo", id);
    }

    private async Task SetTheme(string theme)
    {
        ThemeService.SetTheme(theme);
        await JS.InvokeVoidAsync("portfolio.applyTheme", theme);
    }
}