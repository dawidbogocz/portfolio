@inject IJSRuntime JS
@inject HttpClient Http
@implements IAsyncDisposable

<div class="platformer-wrapper">
    <div class="platformer-header">
        <h3>Procedural Platformer</h3>
        <div class="platformer-controls">
            <span class="badge-score" id="score-display-@ElementId">Score: 0</span>
            <span class="badge-score">Seed: <span id="seed-display-@ElementId">--</span></span>
            <button class="restart-btn" @onclick="NewLevel">New Level</button>
        </div>
    </div>
    <div class="platformer-canvas-container">
        <canvas id="@ElementId" class="platformer-canvas" width="800" height="450"></canvas>
    </div>
    <div class="platformer-footer">
        <span class="key-hint">W / Space</span> Jump (double jump in air)
        <span class="key-hint">A / D</span> Move
        <span class="key-hint">R</span> New Level
    </div>
    <div class="platformer-footer-note">
        Each level is generated on the server by seed. Stomp enemies [W + down], avoid spikes, collect coins! Double jump helps with tricky sections.
    </div>

    @if (statusMessage != null)
    {
        <div class="platformer-status">@statusMessage</div>
    }
</div>

<style>
    .platformer-wrapper {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.75rem;
        width: 100%;
        max-width: 840px;
        margin: 0 auto;
    }
    .platformer-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        width: 100%;
    }
    .platformer-header h3 {
        margin: 0;
        color: var(--accent);
        font-family: 'JetBrains Mono', 'Consolas', monospace;
        font-size: 1.1rem;
    }
    .platformer-controls {
        display: flex;
        align-items: center;
        gap: 1rem;
    }
    .badge-score {
        background: var(--card-bg);
        border: 1px solid var(--border);
        border-radius: 6px;
        padding: 4px 12px;
        font-family: 'JetBrains Mono', 'Consolas', monospace;
        font-size: 0.85rem;
        color: var(--text);
    }
    .restart-btn {
        padding: 6px 16px;
        background: var(--accent);
        color: var(--bg);
        border: none;
        border-radius: 6px;
        font-size: 0.85rem;
        font-weight: 600;
        cursor: pointer;
        font-family: inherit;
        transition: background 0.2s ease;
    }
    .restart-btn:hover {
        background: var(--accent-hover);
    }
    .platformer-canvas-container {
        border: 1px solid var(--border);
        border-radius: 8px;
        overflow: hidden;
        width: 100%;
        display: flex;
        justify-content: center;
    }
    .platformer-canvas {
        display: block;
        width: 100%;
        max-width: 800px;
        height: auto;
        aspect-ratio: 800 / 450;
    }
    .platformer-footer {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem 1.2rem;
        justify-content: center;
        color: var(--text-secondary);
        font-size: 0.8rem;
        font-family: 'JetBrains Mono', 'Consolas', monospace;
    }
    .platformer-footer-note {
        color: var(--text-secondary);
        font-size: 0.75rem;
        opacity: 0.7;
    }
    .key-hint {
        display: inline-block;
        padding: 1px 6px;
        background: var(--card-bg);
        border: 1px solid var(--border);
        border-radius: 4px;
        font-size: 0.75rem;
        color: var(--accent);
        font-weight: 600;
    }
    .platformer-status {
        padding: 8px 16px;
        background: var(--card-bg);
        border: 1px solid var(--border);
        border-radius: 6px;
        color: var(--text-secondary);
        font-size: 0.85rem;
        font-family: 'JetBrains Mono', monospace;
    }
</style>

@code {
    private string ElementId = $"platformer-canvas-{Guid.NewGuid():N}";
    private IJSObjectReference? _jsModule;
    private Timer? _scoreTimer;
    private CancellationTokenSource? _cts;
    private string? statusMessage;
    private bool _disposed;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _cts = new CancellationTokenSource();
            _jsModule = await JS.InvokeAsync<IJSObjectReference>("import", "../js/platformer.js");
            await LoadNewLevel();
        }
    }

    private async Task LoadNewLevel()
    {
        if (_disposed) return;
        statusMessage = "Generating level...";
        StateHasChanged();

        try
        {
            var response = await Http.GetAsync("/api/game/level", _cts!.Token);
            response.EnsureSuccessStatusCode();
            var levelData = await response.Content.ReadAsStringAsync();

            if (_disposed || _cts.IsCancellationRequested) return;

            // Start timer to detect game over
            _scoreTimer?.Dispose();
            var cts = _cts;
            _scoreTimer = new Timer(async _ =>
            {
                if (_disposed || cts.IsCancellationRequested || _jsModule == null) return;
                try
                {
                    var alive = await _jsModule.InvokeAsync<bool>("isAlive", cts.Token);
                    if (!alive)
                    {
                        var score = await _jsModule.InvokeAsync<int>("getScore", cts.Token);
                        var kills = await _jsModule.InvokeAsync<int>("getKills", cts.Token);
                        await SubmitScore(score, kills);
                    }
                }
                catch (JSException) { /* component disposed - safe to ignore */ }
                catch (OperationCanceledException) { /* component disposed - cancelled cleanly */ }
                catch (ObjectDisposedException) { /* disposed */ }
                catch { }
            }, null, 0, 500);

            await _jsModule!.InvokeVoidAsync("start", _cts!.Token, ElementId);
            await _jsModule!.InvokeVoidAsync("loadLevel", _cts!.Token, ElementId, levelData);
            var seed = await _jsModule.InvokeAsync<int>("getSeed", _cts!.Token);
            await JS.InvokeVoidAsync("portfolio.updateElementText", $"seed-display-{ElementId}", seed.ToString());

            statusMessage = null;
            if (!_disposed) StateHasChanged();
        }
        catch (Exception ex)
        {
            if (!_disposed)
            {
                statusMessage = $"Failed to load level: {ex.Message}";
                StateHasChanged();
            }
        }
    }

    private async Task SubmitScore(int score, int kills)
    {
        _scoreTimer?.Dispose();
        _scoreTimer = null;
        if (_disposed || _cts?.IsCancellationRequested == true) return;

        try
        {
            var seed = await _jsModule!.InvokeAsync<int>("getSeed", _cts!.Token);
            var payload = new { playerName = "DzeyD", score, seed, kills };
            var json = System.Text.Json.JsonSerializer.Serialize(payload);
            var content = new StringContent(json, System.Text.Encoding.UTF8, "application/json");
            await Http.PostAsync("/api/game/score", content, _cts!.Token);

            // Fetch leaderboard
            var lbResponse = await Http.GetAsync("/api/game/leaderboard?top=5", _cts!.Token);
            if (lbResponse.IsSuccessStatusCode)
            {
                var lbData = await lbResponse.Content.ReadAsStringAsync();
                await _jsModule!.InvokeVoidAsync("showLeaderboard", _cts!.Token, lbData);
            }
        }
        catch (JSException) { /* disposed */ }
        catch (OperationCanceledException) { /* disposed */ }
        catch { }
    }

    private async void NewLevel()
    {
        await LoadNewLevel();
    }

    public async ValueTask DisposeAsync()
    {
        _disposed = true;
        _cts?.Cancel();
        _scoreTimer?.Dispose();
        _scoreTimer = null;
        try
        {
            if (_jsModule != null)
            {
                await _jsModule.InvokeVoidAsync("stop");
                await _jsModule.DisposeAsync();
            }
        }
        catch { }
        _cts?.Dispose();
        GC.SuppressFinalize(this);
    }
}