@implements IDisposable

<div class="typing-game-wrapper">
    <div class="typing-game-header">
        <div class="typing-stats">
            <div class="typing-stat">
                <span class="typing-stat-label">WPM</span>
                <span class="typing-stat-value">@Wpm</span>
            </div>
            <div class="typing-stat">
                <span class="typing-stat-label">Accuracy</span>
                <span class="typing-stat-value">@Accuracy%</span>
            </div>
            <div class="typing-stat">
                <span class="typing-stat-label">Time</span>
                <span class="typing-stat-value">@FormatTime(ElapsedSeconds)</span>
            </div>
        </div>
        <div class="typing-game-actions">
            <button class="typing-btn" @onclick="NewSnippet" disabled="@(IsRunning)">New Snippet</button>
            <button class="typing-btn typing-btn-back" @onclick="() => OnBack?.Invoke()">← Back</button>
        </div>
    </div>

    @* Source code panel *@
    <div class="typing-source-panel">
        <div class="typing-source-label">Type this code:</div>
        <pre class="typing-source-code"><code>@CurrentSnippet</code></pre>
    </div>

    @* Typing area with character overlay *@
    <div class="typing-area-wrapper">
        <div class="typing-char-overlay" @onclick="FocusTextarea">
            @if (!string.IsNullOrEmpty(CurrentSnippet))
            {
                @for (int i = 0; i < Math.Max(CurrentSnippet.Length, UserInput.Length); i++)
                {
                    var sourceChar = i < CurrentSnippet.Length ? CurrentSnippet[i] : ' ';
                    var userChar = i < UserInput.Length ? UserInput[i] : ' ';
                    var cls = GetCharClass(i, sourceChar, userChar);
                    <span class="@cls">@HtmlChar(sourceChar)</span>
                }
                @if (UserInput.Length < CurrentSnippet.Length && IsRunning)
                {
                    <span class="typing-cursor"></span>
                }
            }
        </div>
        <textarea class="typing-textarea"
                  value="@UserInput"
                  @oninput="OnTextChanged"
                  @ref="textareaRef"
                  @onfocus="OnTextareaFocus"
                  placeholder="@placeholderText"
                  spellcheck="false"
                  autocomplete="off"
                  autocorrect="off"
                  autocapitalize="off"
                  rows="4"
                  disabled="@(!IsRunning && !IsGameOver)"></textarea>
    </div>

    @* Progress bar *@
    @if (!string.IsNullOrEmpty(CurrentSnippet))
    {
        <div class="typing-progress-bar">
            <div class="typing-progress-fill" style="width: @ProgressPercent%"></div>
        </div>
    }

    @* Instructions *@
    <div class="typing-instructions">
        @if (!GameStarted && !IsGameOver)
        {
            <span>Start typing to begin — you have 30 seconds!</span>
        }
        else if (IsRunning)
        {
            <span>⏱️ @RemainingSeconds seconds remaining</span>
        }
    </div>

    @* Game Over Overlay *@
    @if (IsGameOver)
    {
        <div class="typing-game-over-overlay">
            <div class="typing-game-over-content">
                <div class="typing-game-over-title">Time's Up!</div>
                <div class="typing-final-stats">
                    <div class="typing-final-stat">
                        <span class="typing-final-stat-label">WPM</span>
                        <span class="typing-final-stat-value">@FinalWpm</span>
                    </div>
                    <div class="typing-final-stat">
                        <span class="typing-final-stat-label">Accuracy</span>
                        <span class="typing-final-stat-value">@FinalAccuracy%</span>
                    </div>
                    <div class="typing-final-stat">
                        <span class="typing-final-stat-label">Characters</span>
                        <span class="typing-final-stat-value">@CorrectChars / @TotalTyped</span>
                    </div>
                </div>
                <button class="typing-btn typing-btn-primary" @onclick="NewSnippet">Try Again</button>
                <button class="typing-btn typing-btn-back" @onclick="() => OnBack?.Invoke()">← Back to Games</button>
            </div>
        </div>
    }
</div>

@code {
    // === PARAMETERS ===

    /// <summary>
    /// Callback invoked when the user clicks the "Back" button to return to the games menu.
    /// </summary>
    [Parameter]
    public Action? OnBack { get; set; }

    // === CONSTANTS ===

    /// <summary>
    /// Total duration of a typing test round in seconds.
    /// </summary>
    private const int GameDurationSeconds = 30;

    // === CODE SNIPPETS ===

    /// <summary>
    /// Collection of C# code snippets displayed for the user to type.
    /// A random snippet is selected at the start of each round.
    /// </summary>
    private static readonly string[] CodeSnippets =
    [
        "Console.WriteLine(\"Hello, World!\");",
        "public class Program\n{\n    static void Main()\n    {\n        Console.WriteLine(\"Hello!\");\n    }\n}",
        "var numbers = new List<int> { 1, 2, 3, 4, 5 };\nvar sum = numbers.Sum();\nConsole.WriteLine(sum);",
        "public class Calculator\n{\n    public int Add(int a, int b)\n    {\n        return a + b;\n    }\n}",
        "string name = \"World\";\nConsole.WriteLine($\"Hello, {name}!\");",
        "for (int i = 0; i < 10; i++)\n{\n    Console.WriteLine(i);\n}"
    ];

    // === GAME STATE FIELDS ===

    /// <summary>
    /// The current code snippet the user is typing. Set by <see cref="SelectRandomSnippet"/>.
    /// </summary>
    private string CurrentSnippet = string.Empty;

    /// <summary>
    /// The user's current input text, updated on every keystroke.
    /// </summary>
    private string UserInput = string.Empty;

    /// <summary>
    /// Placeholder text displayed in the textarea when no input has been entered yet.
    /// </summary>
    private string placeholderText = "Type the code above here...";

    // === STATS FIELDS ===

    /// <summary>
    /// Live words-per-minute calculation updated every second during the game.
    /// </summary>
    private int Wpm;

    /// <summary>
    /// Live accuracy percentage (correct characters / total typed) updated in real time.
    /// </summary>
    private int Accuracy;

    /// <summary>
    /// Seconds elapsed since the game started.
    /// </summary>
    private int ElapsedSeconds;

    /// <summary>
    /// Seconds remaining in the current round (countdown from <see cref="GameDurationSeconds"/>).
    /// </summary>
    private int RemainingSeconds = GameDurationSeconds;

    /// <summary>
    /// Total number of correctly typed characters across the full input.
    /// </summary>
    private int CorrectChars;

    /// <summary>
    /// Total number of characters typed by the user so far.
    /// </summary>
    private int TotalTyped;

    /// <summary>
    /// Final WPM displayed on the game-over overlay.
    /// </summary>
    private int FinalWpm;

    /// <summary>
    /// Final accuracy percentage displayed on the game-over overlay.
    /// </summary>
    private int FinalAccuracy;

    /// <summary>
    /// Progress through the current snippet as a percentage (0–100).
    /// </summary>
    private double ProgressPercent;

    // === GAME FLOW FIELDS ===

    /// <summary>
    /// Whether the user has started typing (triggers timer start on first keystroke).
    /// </summary>
    private bool GameStarted;

    /// <summary>
    /// Whether the game timer is actively running.
    /// </summary>
    private bool IsRunning;

    /// <summary>
    /// Whether the game-over overlay should be displayed.
    /// </summary>
    private bool IsGameOver;

    // === INTERNAL FIELDS ===

    /// <summary>
    /// System timer that fires every second to track elapsed time and trigger game-end.
    /// </summary>
    private Timer? _gameTimer;

    /// <summary>
    /// Blazor element reference for the hidden textarea, used to programmatically set focus.
    /// </summary>
    private ElementReference textareaRef;

    // === LIFECYCLE METHODS ===

    /// <summary>
    /// Called when the component is first initialized. Selects a random code snippet to display.
    /// </summary>
    protected override void OnInitialized()
    {
        SelectRandomSnippet();
    }

    /// <summary>
    /// Called after each render of the component. On the first render, focuses the hidden textarea
    /// so the user can begin typing immediately without clicking.
    /// </summary>
    /// <param name="firstRender">Whether this is the first render of the component.</param>
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await textareaRef.FocusAsync();
        }
    }

    // === GAME MANAGEMENT ===

    /// <summary>
    /// Selects a random code snippet from <see cref="CodeSnippets"/> and resets all game state.
    /// </summary>
    private void SelectRandomSnippet()
    {
        CurrentSnippet = CodeSnippets[Random.Shared.Next(CodeSnippets.Length)];
        ResetGame();
    }

    /// <summary>
    /// Resets all game state fields, stats, and the timer to their initial values.
    /// </summary>
    private void ResetGame()
    {
        UserInput = string.Empty;
        Wpm = 0;
        Accuracy = 100;
        ElapsedSeconds = 0;
        RemainingSeconds = GameDurationSeconds;
        CorrectChars = 0;
        TotalTyped = 0;
        ProgressPercent = 0;
        GameStarted = false;
        IsRunning = false;
        IsGameOver = false;
        _gameTimer?.Dispose();
        _gameTimer = null;
        placeholderText = "Type the code above here...";
    }

    /// <summary>
    /// Resets the game, selects a new random snippet, and focuses the textarea for immediate typing.
    /// Called when the user clicks "New Snippet" or "Try Again".
    /// </summary>
    private void NewSnippet()
    {
        ResetGame();
        SelectRandomSnippet();
        _ = FocusInput();
    }

    /// <summary>
    /// Delays briefly then focuses the textarea, ensuring the DOM has updated before setting focus.
    /// </summary>
    private async Task FocusInput()
    {
        await Task.Delay(50);
        await textareaRef.FocusAsync();
    }

    /// <summary>
    /// Placeholder handler for textarea focus event. Currently a no-op that returns immediately.
    /// </summary>
    private async Task OnTextareaFocus()
    {
        await Task.CompletedTask;
    }

    /// <summary>
    /// Focuses the hidden textarea when the character overlay is clicked.
    /// </summary>
    private async Task FocusTextarea()
    {
        await textareaRef.FocusAsync();
    }

    // === INPUT HANDLING ===

    /// <summary>
    /// Handles every keystroke from the user. Clamps input to snippet length, starts the timer on
    /// the first keystroke, updates <see cref="UserInput"/>, and recalculates all live stats.
    /// </summary>
    /// <param name="e">The change event args containing the new textarea value.</param>
    private void OnTextChanged(ChangeEventArgs e)
    {
        var newValue = e.Value?.ToString() ?? string.Empty;

        // Prevent typing beyond snippet length
        if (newValue.Length > CurrentSnippet.Length)
        {
            newValue = newValue[..CurrentSnippet.Length];
        }

        // Start timer on first keystroke
        if (!GameStarted && newValue.Length > 0)
        {
            GameStarted = true;
            IsRunning = true;
            StartTimer();
        }

        UserInput = newValue;
        UpdateStats();
    }

    // === TIMER ===

    /// <summary>
    /// Starts a one-second-interval timer that increments the elapsed seconds count, updates the
    /// remaining-seconds display, triggers <see cref="EndGame"/> when time runs out, recalculates
    /// WPM, and re-renders the component.
    /// </summary>
    private void StartTimer()
    {
        _gameTimer?.Dispose();
        _gameTimer = new Timer(_ =>
        {
            InvokeAsync(() =>
            {
                ElapsedSeconds++;
                RemainingSeconds = GameDurationSeconds - ElapsedSeconds;

                if (ElapsedSeconds >= GameDurationSeconds)
                {
                    EndGame();
                }

                UpdateWpm();
                StateHasChanged();
            });
        }, null, 1000, 1000);
    }

    // === STATS CALCULATION ===

    /// <summary>
    /// Recalculates all live stats: total typed characters, correct character count, progress
    /// percentage, WPM, and accuracy. Called on every keystroke.
    /// </summary>
    private void UpdateStats()
    {
        TotalTyped = UserInput.Length;
        CorrectChars = 0;

        for (int i = 0; i < UserInput.Length; i++)
        {
            if (i < CurrentSnippet.Length && UserInput[i] == CurrentSnippet[i])
            {
                CorrectChars++;
            }
        }

        ProgressPercent = CurrentSnippet.Length > 0
            ? (double)UserInput.Length / CurrentSnippet.Length * 100
            : 0;

        UpdateWpm();
        UpdateAccuracy();
    }

    /// <summary>
    /// Calculates the live WPM using the standard formula: (correct characters / 5) / minutes elapsed.
    /// Returns 0 if no time has elapsed.
    /// </summary>
    private void UpdateWpm()
    {
        if (ElapsedSeconds > 0)
        {
            // Standard WPM: (characters / 5) / minutes
            double minutes = ElapsedSeconds / 60.0;
            Wpm = minutes > 0 ? (int)(CorrectChars / 5.0 / minutes) : 0;
        }
        else
        {
            Wpm = 0;
        }
    }

    /// <summary>
    /// Calculates the live accuracy percentage as (correct characters / total typed) × 100.
    /// Returns 100% if nothing has been typed yet.
    /// </summary>
    private void UpdateAccuracy()
    {
        if (TotalTyped > 0)
        {
            Accuracy = (int)((double)CorrectChars / TotalTyped * 100);
        }
        else
        {
            Accuracy = 100;
        }
    }

    // === GAME END ===

    /// <summary>
    /// Ends the current round: stops the timer, disposes it, marks the game as over, and captures
    /// the final WPM and accuracy for display in the game-over overlay.
    /// </summary>
    private void EndGame()
    {
        IsRunning = false;
        IsGameOver = true;
        _gameTimer?.Dispose();
        _gameTimer = null;

        // Calculate final stats based on full input
        FinalWpm = Wpm;
        FinalAccuracy = Accuracy;
    }

    // === UI HELPERS ===

    /// <summary>
    /// Returns the CSS class string for a character in the overlay display based on whether it has
    /// been typed, and whether it matches the source character. Handles newline characters
    /// specially with their own class.
    /// </summary>
    /// <param name="index">Position of the character in the source string.</param>
    /// <param name="sourceChar">The expected character from the code snippet.</param>
    /// <param name="userChar">The character the user actually typed.</param>
    /// <returns>A space-separated CSS class string for the character span.</returns>
    private string GetCharClass(int index, char sourceChar, char userChar)
    {
        if (index >= UserInput.Length)
        {
            return "typing-char typing-char-untyped";
        }

        if (sourceChar == '\n')
        {
            return userChar == '\n' ? "typing-char typing-char-newline typing-char-correct"
                                    : "typing-char typing-char-newline typing-char-incorrect";
        }

        if (sourceChar == userChar)
        {
            return "typing-char typing-char-correct";
        }

        return "typing-char typing-char-incorrect";
    }

    /// <summary>
    /// Converts a character to its HTML-safe display representation. Spaces become non-breaking
    /// spaces, newlines show a ↵ marker followed by a real newline, tabs become four spaces,
    /// and HTML special characters are escaped.
    /// </summary>
    /// <param name="c">The character to convert.</param>
    /// <returns>A string safe for direct rendering in HTML.</returns>
    private static string HtmlChar(char c)
    {
        return c switch
        {
            ' ' => "\u00A0",
            '\n' => "↵\n",
            '\t' => "    ",
            '<' => "&lt;",
            '>' => "&gt;",
            '&' => "&amp;",
            _ => c.ToString()
        };
    }

    /// <summary>
    /// Formats a total number of seconds as a MM:SS string for the timer display.
    /// </summary>
    /// <param name="totalSeconds">The total seconds to format.</param>
    /// <returns>A formatted time string (e.g., "00:45" or "01:30").</returns>
    private static string FormatTime(int totalSeconds)
    {
        var min = totalSeconds / 60;
        var sec = totalSeconds % 60;
        return $"{min:D2}:{sec:D2}";
    }

    // === CLEANUP ===

    /// <summary>
    /// Disposes the game timer when the component is removed from the render tree.
    /// Implements <see cref="IDisposable"/> to prevent timer leaks.
    /// </summary>
    public void Dispose()
    {
        _gameTimer?.Dispose();
    }
}

<style>
    .typing-game-wrapper {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 1rem;
        padding: 1rem;
        font-family: 'Segoe UI', system-ui, sans-serif;
        position: relative;
        user-select: none;
        width: 100%;
        max-width: 700px;
        margin: 0 auto;
    }

    .typing-game-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        width: 100%;
        padding: 0.75rem 1rem;
        background: #1a1a2e;
        border-radius: 8px;
        border: 1px solid #16213e;
    }

    .typing-stats {
        display: flex;
        gap: 1.2rem;
    }

    .typing-stat {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.1rem;
    }

    .typing-stat-label {
        font-size: 0.7rem;
        color: #888;
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }

    .typing-stat-value {
        font-size: 1.1rem;
        font-weight: 700;
        color: #e0e0e0;
        font-variant-numeric: tabular-nums;
    }

    .typing-game-actions {
        display: flex;
        gap: 0.5rem;
    }

    .typing-btn {
        padding: 0.4rem 0.9rem;
        border: 1px solid #333;
        border-radius: 6px;
        background: #16213e;
        color: #e0e0e0;
        font-size: 0.85rem;
        cursor: pointer;
        transition: background 0.15s, border-color 0.15s;
        font-family: inherit;
    }

    .typing-btn:hover:not(:disabled) {
        background: #1a1a3e;
        border-color: #4caf50;
    }

    .typing-btn:disabled {
        opacity: 0.5;
        cursor: not-allowed;
    }

    .typing-btn-back {
        border-color: #533483;
    }

    .typing-btn-back:hover {
        border-color: #7b2d8b;
        background: #2a1a3e;
    }

    .typing-btn-primary {
        background: #4caf50;
        color: #fff;
        border-color: #4caf50;
        font-weight: 600;
        padding: 0.6rem 1.4rem;
        font-size: 1rem;
    }

    .typing-btn-primary:hover {
        background: #43a047;
        border-color: #43a047;
    }

    /* Source panel */
    .typing-source-panel {
        width: 100%;
        background: #1e1e2e;
        border: 1px solid #333;
        border-radius: 8px;
        padding: 1rem;
    }

    .typing-source-label {
        font-size: 0.75rem;
        color: #888;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        margin-bottom: 0.5rem;
    }

    .typing-source-code {
        margin: 0;
        padding: 0.75rem;
        background: #0f0f23;
        border-radius: 6px;
        font-family: 'Cascadia Code', 'Fira Code', 'JetBrains Mono', 'Consolas', monospace;
        font-size: 0.9rem;
        line-height: 1.6;
        color: #569cd6;
        white-space: pre;
        overflow-x: auto;
    }

    /* Typing area */
    .typing-area-wrapper {
        position: relative;
        width: 100%;
    }

    .typing-char-overlay {
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        padding: 0.75rem;
        font-family: 'Cascadia Code', 'Fira Code', 'JetBrains Mono', 'Consolas', monospace;
        font-size: 0.9rem;
        line-height: 1.6;
        white-space: pre-wrap;
        word-break: break-all;
        pointer-events: auto;
        cursor: text;
        z-index: 1;
        min-height: 80px;
    }

    .typing-char {
        transition: color 0.05s;
    }

    .typing-char-untyped {
        color: #555;
    }

    .typing-char-correct {
        color: #4caf50;
    }

    .typing-char-incorrect {
        color: #f44336;
        background: rgba(244, 67, 54, 0.15);
        border-radius: 2px;
    }

    .typing-char-newline {
        display: inline;
    }

    .typing-cursor {
        display: inline-block;
        width: 2px;
        height: 1.2em;
        background: #569cd6;
        animation: typing-blink 0.8s step-end infinite;
        vertical-align: text-bottom;
        margin-left: 1px;
    }

    @@keyframes typing-blink {
        0%, 100% { opacity: 1; }
        50% { opacity: 0; }
    }

    .typing-textarea {
        width: 100%;
        padding: 0.75rem;
        border: 1px solid #333;
        border-radius: 8px;
        background: #1a1a2e;
        color: transparent;
        caret-color: #569cd6;
        font-family: 'Cascadia Code', 'Fira Code', 'JetBrains Mono', 'Consolas', monospace;
        font-size: 0.9rem;
        line-height: 1.6;
        resize: none;
        outline: none;
        transition: border-color 0.15s;
        min-height: 80px;
    }

    .typing-textarea:focus {
        border-color: #569cd6;
        box-shadow: 0 0 0 2px rgba(86, 156, 214, 0.2);
    }

    .typing-textarea:disabled {
        opacity: 0.6;
        cursor: default;
    }

    .typing-textarea::placeholder {
        color: #555;
    }

    /* Progress bar */
    .typing-progress-bar {
        width: 100%;
        height: 6px;
        background: #1a1a2e;
        border-radius: 3px;
        overflow: hidden;
        border: 1px solid #16213e;
    }

    .typing-progress-fill {
        height: 100%;
        background: linear-gradient(90deg, #4caf50, #66bb6a);
        border-radius: 3px;
        transition: width 0.15s ease;
    }

    /* Instructions */
    .typing-instructions {
        font-size: 0.85rem;
        color: #888;
        text-align: center;
    }

    /* Game Over Overlay */
    .typing-game-over-overlay {
        position: absolute;
        inset: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        background: rgba(0, 0, 0, 0.75);
        backdrop-filter: blur(4px);
        z-index: 10;
        border-radius: 8px;
    }

    .typing-game-over-content {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.8rem;
        padding: 2rem;
        background: #1a1a2e;
        border-radius: 12px;
        border: 1px solid #333;
        box-shadow: 0 8px 32px rgba(0, 0, 0, 0.4);
    }

    .typing-game-over-title {
        font-size: 2rem;
        font-weight: 700;
        color: #f44336;
        text-shadow: 0 0 10px rgba(244, 67, 54, 0.5);
    }

    .typing-final-stats {
        display: flex;
        gap: 1.5rem;
        margin: 0.5rem 0;
    }

    .typing-final-stat {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.2rem;
    }

    .typing-final-stat-label {
        font-size: 0.7rem;
        color: #888;
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }

    .typing-final-stat-value {
        font-size: 1.6rem;
        font-weight: 700;
        color: #4caf50;
        font-variant-numeric: tabular-nums;
    }
</style>