@implements IAsyncDisposable
@using System.Threading

<div class="snake-game-wrapper"
     @onkeydown="@HandleKeyDown"
     tabindex="0"
     @ref="containerRef">
    <div class="snake-game-header">
        <div class="snake-score">Score: <span>@score</span></div>
        <div class="snake-game-actions">
            <button class="snake-btn" @onclick="RestartGame">Restart</button>
            <button class="snake-btn snake-btn-back" @onclick="() => OnBack?.Invoke()">← Back</button>
        </div>
    </div>

    <div class="snake-board">
        @for (int y = 0; y < GridSize; y++)
        {
            @for (int x = 0; x < GridSize; x++)
            {
                var cellType = GetCellType(x, y);
                <div class="snake-cell snake-cell-@cellType"
                     style="grid-column: @(x + 1); grid-row: @(y + 1);"></div>
            }
        }
    </div>

    @if (gameOver)
    {
        <div class="snake-game-over-overlay">
            <div class="snake-game-over-content">
                <div class="snake-game-over-title">Game Over!</div>
                <div class="snake-final-score">Score: @score</div>
                <button class="snake-btn snake-btn-primary" @onclick="RestartGame">Play Again</button>
                <button class="snake-btn snake-btn-back" @onclick="() => OnBack?.Invoke()">← Back to Games</button>
            </div>
        </div>
    }

    @* Mobile-friendly on-screen controls *@
    <div class="snake-mobile-controls">
        <button class="snake-mob-btn" @onclick="() => ChangeDirection(Direction.Up)" aria-label="Up">▲</button>
        <div class="snake-mob-row">
            <button class="snake-mob-btn" @onclick="() => ChangeDirection(Direction.Left)" aria-label="Left">◀</button>
            <button class="snake-mob-btn" @onclick="() => ChangeDirection(Direction.Down)" aria-label="Down">▼</button>
            <button class="snake-mob-btn" @onclick="() => ChangeDirection(Direction.Right)" aria-label="Right">▶</button>
        </div>
    </div>
</div>

@code {
    // === PARAMETERS ===

    /// <summary>
    /// Callback invoked when the user wants to navigate back from the game.
    /// </summary>
    [Parameter]
    public Action? OnBack { get; set; }

    // === CONSTANTS ===

    /// <summary>Number of cells per row and column in the square game grid.</summary>
    private const int GridSize = 20;

    /// <summary>Width and height of each cell in pixels for CSS grid layout.</summary>
    private const int CellSizePx = 24;

    /// <summary>Starting interval between game ticks in milliseconds.</summary>
    private const int InitialSpeedMs = 150;

    /// <summary>Minimum interval between game ticks (fastest speed) in milliseconds.</summary>
    private const int MinSpeedMs = 50;

    /// <summary>Number of food items eaten before the game speed increases.</summary>
    private const int SpeedUpInterval = 5;

    // === ENUMS ===

    /// <summary>Compass direction the snake can move in.</summary>
    private enum Direction { Up, Down, Left, Right }

    /// <summary>Visual state of a single cell on the game board.</summary>
    private enum CellType { Empty, SnakeHead, SnakeBody, SnakeTail, Food }

    // === GAME STATE FIELDS ===

    /// <summary>List of (X, Y) positions representing the snake's segments. Index 0 is the head.</summary>
    private List<(int X, int Y)> snake = new();

    /// <summary>Current (X, Y) position of the food item on the grid.</summary>
    private (int X, int Y) food;

    /// <summary>Direction the snake is currently moving in.</summary>
    private Direction currentDirection = Direction.Right;

    /// <summary>Buffered direction that will take effect on the next tick (prevents 180° reversals in one tick).</summary>
    private Direction nextDirection = Direction.Right;

    /// <summary>Current score, incremented each time the snake eats food.</summary>
    private int score;

    /// <summary>Indicates whether the game has ended (collision with wall or self).</summary>
    private bool gameOver;

    /// <summary>Indicates whether the first tick has occurred (stops rendering before first update).</summary>
    private bool gameStarted;

    /// <summary>Periodic timer driving the game loop ticks.</summary>
    private PeriodicTimer? timer;

    /// <summary>Cancellation token source for stopping the game loop on restart or disposal.</summary>
    private CancellationTokenSource? cts;

    /// <summary>Reference to the wrapper div element, used to set keyboard focus.</summary>
    private ElementReference containerRef;

    // === STATIC DICTIONARIES ===

    /// <summary>Maps each direction to its (deltaX, deltaY) movement vector.</summary>
    private static readonly Dictionary<Direction, (int dx, int dy)> DirectionVectors = new()
    {
        [Direction.Up] = (0, -1),
        [Direction.Down] = (0, 1),
        [Direction.Left] = (-1, 0),
        [Direction.Right] = (1, 0),
    };

    /// <summary>Maps each direction to its opposite (used to prevent 180° reversal).</summary>
    private static readonly Dictionary<Direction, Direction> Opposites = new()
    {
        [Direction.Up] = Direction.Down,
        [Direction.Down] = Direction.Up,
        [Direction.Left] = Direction.Right,
        [Direction.Right] = Direction.Left,
    };

    // === LIFECYCLE METHODS ===

    /// <summary>
    /// Called when the component is first initialized. Sets up the initial game state and starts the game loop.
    /// </summary>
    protected override Task OnInitializedAsync()
    {
        InitializeGame();
        StartGameLoop();
        return Task.CompletedTask;
    }

    /// <summary>
    /// Called after each render pass. On the first render, focuses the game container so keyboard input is captured.
    /// </summary>
    /// <param name="firstRender">True if this is the very first render of the component.</param>
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await containerRef.FocusAsync();
        }
    }

    /// <summary>
    /// Disposes of the timer and cancellation source when the component is torn down.
    /// </summary>
    public ValueTask DisposeAsync()
    {
        cts?.Cancel();
        cts?.Dispose();
        timer?.Dispose();
        return ValueTask.CompletedTask;
    }

    // === GAME INITIALIZATION ===

    /// <summary>
    /// Resets all game state to its initial values: places the snake at the center of the grid
    /// (length 3, moving right), resets the score, and spawns the first food item.
    /// </summary>
    private void InitializeGame()
    {
        // Start snake in the center, length 3, moving right
        int mid = GridSize / 2;
        snake = new List<(int X, int Y)>
        {
            (mid, mid),       // head
            (mid - 1, mid),   // body
            (mid - 2, mid),   // tail
        };
        currentDirection = Direction.Right;
        nextDirection = Direction.Right;
        score = 0;
        gameOver = false;
        gameStarted = false;
        SpawnFood();
    }

    /// <summary>
    /// Randomly places a food item on an unoccupied cell. Does nothing if no cells are available.
    /// </summary>
    private void SpawnFood()
    {
        var occupied = new HashSet<(int, int)>(snake);
        var available = new List<(int X, int Y)>();

        for (int x = 0; x < GridSize; x++)
        {
            for (int y = 0; y < GridSize; y++)
            {
                if (!occupied.Contains((x, y)))
                {
                    available.Add((x, y));
                }
            }
        }

        if (available.Count > 0)
        {
            food = available[Random.Shared.Next(available.Count)];
        }
    }

    // === GAME LOOP ===

    /// <summary>
    /// Starts the async-void game loop. Runs a PeriodicTimer that fires <see cref="Tick"/>
    /// on each interval. The loop cancels gracefully when the component is disposed or restarted.
    /// </summary>
    private async void StartGameLoop()
    {
        cts?.Cancel();
        cts = new CancellationTokenSource();
        var token = cts.Token;

        timer = new PeriodicTimer(TimeSpan.FromMilliseconds(InitialSpeedMs));

        try
        {
            while (await timer.WaitForNextTickAsync(token))
            {
                if (!gameOver)
                {
                    gameStarted = true;
                    Tick();
                    await InvokeAsync(StateHasChanged);
                }
            }
        }
        catch (OperationCanceledException)
        {
            // Expected on disposal or restart
        }
    }

    /// <summary>
    /// Async task-based game loop used after a restart. Replaces the old loop by canceling
    /// the previous <see cref="CancellationTokenSource"/> and creating a fresh one.
    /// </summary>
    private async Task StartGameLoopAsync()
    {
        // Ensure we clean up any previous loop
        cts?.Cancel();
        cts?.Dispose();
        cts = new CancellationTokenSource();
        var token = cts.Token;

        timer = new PeriodicTimer(TimeSpan.FromMilliseconds(InitialSpeedMs));

        try
        {
            while (await timer.WaitForNextTickAsync(token))
            {
                if (!gameOver)
                {
                    gameStarted = true;
                    Tick();
                    await InvokeAsync(StateHasChanged);
                }
            }
        }
        catch (OperationCanceledException)
        {
            // Expected
        }
    }

    // === GAME LOGIC ===

    /// <summary>
    /// Advances the game by one tick: applies the buffered direction, computes the new head position,
    /// checks for wall / self collisions, moves the snake, and handles food consumption (including speed scaling).
    /// </summary>
    private void Tick()
    {
        currentDirection = nextDirection;
        var head = snake[0];
        var (dx, dy) = DirectionVectors[currentDirection];
        var newHead = (X: head.X + dx, Y: head.Y + dy);

        // Wall collision
        if (newHead.X < 0 || newHead.X >= GridSize || newHead.Y < 0 || newHead.Y >= GridSize)
        {
            gameOver = true;
            return;
        }

        // Self collision (check against all segments except the tail, which will move)
        // If we eat food, tail stays, so check all segments
        bool willEat = newHead == food;
        var checkSegments = willEat ? snake : snake.Take(snake.Count - 1).ToList();

        if (checkSegments.Any(s => s == newHead))
        {
            gameOver = true;
            return;
        }

        // Move snake
        snake.Insert(0, newHead);

        if (willEat)
        {
            score++;
            SpawnFood();
            // Adjust speed every SpeedUpInterval points
            if (timer is not null && score % SpeedUpInterval == 0)
            {
                int newSpeed = Math.Max(MinSpeedMs, InitialSpeedMs - (score / SpeedUpInterval) * 10);
                timer.Period = TimeSpan.FromMilliseconds(newSpeed);
            }
        }
        else
        {
            snake.RemoveAt(snake.Count - 1);
        }
    }

    /// <summary>
    /// Returns the <see cref="CellType"/> for a given grid coordinate, used to render the appropriate CSS class.
    /// Checks in order: snake head, snake tail, any snake body segment, food, empty.
    /// </summary>
    /// <param name="x">X coordinate (column) on the grid.</param>
    /// <param name="y">Y coordinate (row) on the grid.</param>
    /// <returns>The cell type for the given position.</returns>
    private CellType GetCellType(int x, int y)
    {
        if (snake.Count > 0 && snake[0] == (x, y))
            return CellType.SnakeHead;

        if (snake.Count > 1 && snake[^1] == (x, y))
            return CellType.SnakeTail;

        if (snake.Any(s => s == (x, y)))
            return CellType.SnakeBody;

        if (food == (x, y))
            return CellType.Food;

        return CellType.Empty;
    }

    // === INPUT HANDLING ===

    /// <summary>
    /// Attempts to change the snake's direction. Ignores the input if it would cause
    /// a 180° reversal (e.g. going left while currently moving right).
    /// </summary>
    /// <param name="dir">The new direction requested by the user.</param>
    private void ChangeDirection(Direction dir)
    {
        if (Opposites[dir] != currentDirection)
        {
            nextDirection = dir;
        }
    }

    /// <summary>
    /// Handles keyboard input. Arrow keys, WASD, and HJKL change direction.
    /// R restarts the game.
    /// </summary>
    /// <param name="e">Keyboard event arguments containing the pressed key.</param>
    private void HandleKeyDown(KeyboardEventArgs e)
    {
        switch (e.Key)
        {
            case "ArrowUp" or "w" or "W":
                ChangeDirection(Direction.Up);
                break;
            case "ArrowDown" or "s" or "S":
                ChangeDirection(Direction.Down);
                break;
            case "ArrowLeft" or "a" or "A":
                ChangeDirection(Direction.Left);
                break;
            case "ArrowRight" or "d" or "D":
                ChangeDirection(Direction.Right);
                break;
            case "r" or "R":
                RestartGame();
                break;
        }
    }

    /// <summary>
    /// Restarts the game: resets game state, disposes the old timer, and starts a fresh async game loop.
    /// </summary>
    private void RestartGame()
    {
        InitializeGame();
        // Restart the game loop with fresh timer
        timer?.Dispose();
        _ = StartGameLoopAsync();
    }
}

<style>
    .snake-game-wrapper {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 1rem;
        padding: 1rem;
        outline: none;
        user-select: none;
        font-family: 'Segoe UI', system-ui, sans-serif;
    }

    .snake-game-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        width: 100%;
        max-width: 480px;
        padding: 0.5rem 1rem;
        background: #1a1a2e;
        border-radius: 8px;
        border: 1px solid #16213e;
    }

    .snake-score {
        color: #e0e0e0;
        font-size: 1.2rem;
        font-weight: 600;
    }

    .snake-score span {
        color: #4caf50;
        font-size: 1.4rem;
    }

    .snake-game-actions {
        display: flex;
        gap: 0.5rem;
    }

    .snake-btn {
        padding: 0.4rem 0.9rem;
        border: 1px solid #333;
        border-radius: 6px;
        background: #16213e;
        color: #e0e0e0;
        font-size: 0.85rem;
        cursor: pointer;
        transition: background 0.15s, border-color 0.15s;
    }

    .snake-btn:hover {
        background: #1a1a3e;
        border-color: #4caf50;
    }

    .snake-btn-back {
        border-color: #533483;
    }

    .snake-btn-back:hover {
        border-color: #7b2d8b;
        background: #2a1a3e;
    }

    .snake-btn-primary {
        background: #4caf50;
        color: #fff;
        border-color: #4caf50;
        font-weight: 600;
        padding: 0.6rem 1.4rem;
        font-size: 1rem;
    }

    .snake-btn-primary:hover {
        background: #43a047;
        border-color: #43a047;
    }

    .snake-board {
        display: grid;
        grid-template-columns: repeat(20, 24px);
        grid-template-rows: repeat(20, 24px);
        gap: 1px;
        background: #0f0f23;
        border: 2px solid #1a1a3e;
        border-radius: 4px;
        padding: 1px;
    }

    .snake-cell {
        width: 24px;
        height: 24px;
        border-radius: 2px;
        transition: background 0.05s;
    }

    .snake-cell-empty {
        background: #0f0f23;
    }

    .snake-cell-snakehead {
        background: #4caf50;
        border-radius: 3px;
        box-shadow: 0 0 4px rgba(76, 175, 80, 0.6);
    }

    .snake-cell-snakebody {
        background: #2e7d32;
        border-radius: 2px;
    }

    .snake-cell-snaketail {
        background: #1b5e20;
        border-radius: 2px;
    }

    .snake-cell-food {
        background: #f44336;
        border-radius: 50%;
        box-shadow: 0 0 6px rgba(244, 67, 54, 0.7);
        animation: food-pulse 0.8s ease-in-out infinite alternate;
    }

    @@keyframes food-pulse {
        from {
            box-shadow: 0 0 4px rgba(244, 67, 54, 0.5);
        }
        to {
            box-shadow: 0 0 10px rgba(244, 67, 54, 0.9);
        }
    }

    .snake-game-over-overlay {
        position: absolute;
        inset: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        background: rgba(0, 0, 0, 0.75);
        backdrop-filter: blur(4px);
        z-index: 10;
        border-radius: 8px;
    }

    .snake-game-over-content {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.8rem;
        padding: 2rem;
        background: #1a1a2e;
        border-radius: 12px;
        border: 1px solid #333;
        box-shadow: 0 8px 32px rgba(0, 0, 0, 0.4);
    }

    .snake-game-over-title {
        font-size: 2rem;
        font-weight: 700;
        color: #f44336;
        text-shadow: 0 0 10px rgba(244, 67, 54, 0.5);
    }

    .snake-final-score {
        font-size: 1.2rem;
        color: #e0e0e0;
    }

    .snake-game-wrapper {
        position: relative;
    }

    /* Mobile controls */
    .snake-mobile-controls {
        display: none;
        flex-direction: column;
        align-items: center;
        gap: 0.25rem;
        margin-top: 0.5rem;
    }

    .snake-mob-row {
        display: flex;
        gap: 0.25rem;
    }

    .snake-mob-btn {
        width: 48px;
        height: 48px;
        font-size: 1.2rem;
        background: #16213e;
        border: 1px solid #333;
        border-radius: 8px;
        color: #e0e0e0;
        cursor: pointer;
        touch-action: manipulation;
    }

    .snake-mob-btn:active {
        background: #2a2a4e;
    }

    @@media (pointer: coarse) {
        .snake-mobile-controls {
            display: flex;
        }
    }
</style>