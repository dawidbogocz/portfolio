

<div class="tictactoe-wrapper">
    <div class="tictactoe-header">
        <div class="tictactoe-score">
            <span class="score-label">Wins: </span><span class="score-wins">@wins</span>
            <span class="score-label">Losses: </span><span class="score-losses">@losses</span>
            <span class="score-label">Draws: </span><span class="score-draws">@draws</span>
        </div>
        <div class="tictactoe-status">@statusMessage</div>
        <div class="tictactoe-actions">
            <button class="tictactoe-btn" @onclick="RestartGame">Restart</button>
            <button class="tictactoe-btn tictactoe-btn-back" @onclick="() => OnBack?.Invoke()">← Back</button>
        </div>
    </div>

    <div class="tictactoe-board">
        @for (int i = 0; i < 3; i++)
        {
            @for (int j = 0; j < 3; j++)
            {
                var row = i;
                var col = j;
                var cellValue = board[row, col];
                <div class="tictactoe-cell @GetCellClass(cellValue)"
                     @onclick="() => HandleCellClick(row, col)">
                    @if (cellValue == CellState.X)
                    {
                        <span class="tictactoe-x">X</span>
                    }
                    else if (cellValue == CellState.O)
                    {
                        <span class="tictactoe-o">O</span>
                    }
                </div>
            }
        }
    </div>

    @if (gameOver)
    {
        <div class="tictactoe-overlay">
            <div class="tictactoe-overlay-content">
                <div class="tictactoe-overlay-title">
                    @(winner == CellState.X ? "You Win!" :
                      winner == CellState.O ? "AI Wins!" : "It's a Draw!")
                </div>
                <button class="tictactoe-btn tictactoe-btn-primary" @onclick="RestartGame">Play Again</button>
                <button class="tictactoe-btn tictactoe-btn-back" @onclick="() => OnBack?.Invoke()">← Back to Games</button>
            </div>
        </div>
    }
</div>

@code {
    // ====================================================================
    // Parameters
    // ====================================================================

    /// <summary>
    /// Callback invoked when the user clicks the "Back" button to navigate away from the game.
    /// </summary>
    [Parameter]
    public Action? OnBack { get; set; }

    // ====================================================================
    // Enums
    // ====================================================================

    /// <summary>
    /// Represents the state of a single cell on the Tic-Tac-Toe board.
    /// </summary>
    private enum CellState { Empty, X, O }

    // ====================================================================
    // Game State Fields
    // ====================================================================

    /// <summary>
    /// The 3x3 game board. Each cell holds the state of a player's mark or empty.
    /// </summary>
    private CellState[,] board = new CellState[3, 3];

    /// <summary>
    /// Indicates whether the game has ended (win, loss, or draw).
    /// </summary>
    private bool gameOver;

    /// <summary>
    /// The winning player's cell state, or <see cref="CellState.Empty"/> if the game ended in a draw.
    /// </summary>
    private CellState winner;

    /// <summary>
    /// Total number of player wins across all games in the current session.
    /// </summary>
    private int wins;

    /// <summary>
    /// Total number of AI wins across all games in the current session.
    /// </summary>
    private int losses;

    /// <summary>
    /// Total number of draws across all games in the current session.
    /// </summary>
    private int draws;

    /// <summary>
    /// Status message displayed above the board to inform the player of the current game state (e.g., "Your turn", "AI is thinking...").
    /// </summary>
    private string statusMessage = "Your turn — click a cell to place X";

    /// <summary>
    /// Indicates whether it is the human player's turn (<c>true</c>) or the AI's turn (<c>false</c>).
    /// </summary>
    private bool isPlayerTurn = true;

    // ====================================================================
    // Game Flow Methods
    // ====================================================================

    /// <summary>
    /// Handles a click on a board cell by the human player. Places an X, checks for win/draw,
    /// and triggers the AI move if the game is still ongoing.
    /// </summary>
    /// <param name="row">The row index (0-2) of the clicked cell.</param>
    /// <param name="col">The column index (0-2) of the clicked cell.</param>
    private void HandleCellClick(int row, int col)
    {
        if (gameOver || !isPlayerTurn || board[row, col] != CellState.Empty)
            return;

        // Player places X
        board[row, col] = CellState.X;
        isPlayerTurn = false;

        // Check for win/draw after player move
        if (CheckWin(CellState.X))
        {
            winner = CellState.X;
            gameOver = true;
            wins++;
            statusMessage = "You win!";
            return;
        }

        if (IsBoardFull())
        {
            gameOver = true;
            winner = CellState.Empty;
            draws++;
            statusMessage = "It's a draw!";
            return;
        }

        statusMessage = "AI is thinking...";
        // Trigger AI move
        _ = MakeAIMoveAsync();
    }

    /// <summary>
    /// Executes the AI's move asynchronously. Introduces a short delay so the player sees their
    /// own mark before the AI responds, then applies the minimax-calculated best move and
    /// checks for win or draw conditions.
    /// </summary>
    private async Task MakeAIMoveAsync()
    {
        // Small delay so the player sees their mark before AI responds
        await Task.Delay(300);

        if (gameOver)
            return;

        var (aiRow, aiCol) = GetBestMove();
        board[aiRow, aiCol] = CellState.O;
        isPlayerTurn = true;

        if (CheckWin(CellState.O))
        {
            winner = CellState.O;
            gameOver = true;
            losses++;
            statusMessage = "AI wins!";
            return;
        }

        if (IsBoardFull())
        {
            gameOver = true;
            winner = CellState.Empty;
            draws++;
            statusMessage = "It's a draw!";
            return;
        }

        statusMessage = "Your turn — click a cell to place X";
    }

    // ====================================================================
    // AI Logic (Minimax Algorithm)
    // ====================================================================

    /// <summary>
    /// Evaluates all available empty cells and returns the row and column of the best move
    /// for the AI (O) using the minimax algorithm.
    /// </summary>
    /// <returns>A tuple containing the row and column of the optimal move.</returns>
    private (int Row, int Col) GetBestMove()
    {
        int bestScore = int.MinValue;
        int bestRow = -1;
        int bestCol = -1;

        for (int r = 0; r < 3; r++)
        {
            for (int c = 0; c < 3; c++)
            {
                if (board[r, c] == CellState.Empty)
                {
                    board[r, c] = CellState.O;
                    int score = Minimax(board, 0, false);
                    board[r, c] = CellState.Empty;

                    if (score > bestScore)
                    {
                        bestScore = score;
                        bestRow = r;
                        bestCol = c;
                    }
                }
            }
        }

        return (bestRow, bestCol);
    }

    /// <summary>
    /// Recursively evaluates the game tree to determine the optimal score for the current board state.
    /// The AI (maximizing player) seeks the highest score, while the human (minimizing player) seeks
    /// the lowest. Scores are adjusted by depth to favor quicker wins and slower losses.
    /// </summary>
    /// <param name="state">A copy of the current board state to evaluate.</param>
    /// <param name="depth">The current recursion depth, used to bias scores toward earlier outcomes.</param>
    /// <param name="isMaximizing"><c>true</c> if this is the AI's turn (maximizing), <c>false</c> for the human (minimizing).</param>
    /// <returns>An integer score: positive for AI advantage, negative for human advantage, zero for draw.</returns>
    private int Minimax(CellState[,] state, int depth, bool isMaximizing)
    {
        if (CheckWin(CellState.O))
            return 10 - depth;
        if (CheckWin(CellState.X))
            return depth - 10;
        if (IsBoardFull())
            return 0;

        if (isMaximizing)
        {
            int best = int.MinValue;
            for (int r = 0; r < 3; r++)
            {
                for (int c = 0; c < 3; c++)
                {
                    if (state[r, c] == CellState.Empty)
                    {
                        state[r, c] = CellState.O;
                        int score = Minimax(state, depth + 1, false);
                        state[r, c] = CellState.Empty;
                        best = Math.Max(score, best);
                    }
                }
            }
            return best;
        }
        else
        {
            int best = int.MaxValue;
            for (int r = 0; r < 3; r++)
            {
                for (int c = 0; c < 3; c++)
                {
                    if (state[r, c] == CellState.Empty)
                    {
                        state[r, c] = CellState.X;
                        int score = Minimax(state, depth + 1, true);
                        state[r, c] = CellState.Empty;
                        best = Math.Min(score, best);
                    }
                }
            }
            return best;
        }
    }

    // ====================================================================
    // Win / Draw Detection
    // ====================================================================

    /// <summary>
    /// Checks whether the specified player has achieved a winning configuration
    /// on the current board (three in a row horizontally, vertically, or diagonally).
    /// </summary>
    /// <param name="player">The player to check (<see cref="CellState.X"/> or <see cref="CellState.O"/>).</param>
    /// <returns><c>true</c> if the player has three in a row; otherwise <c>false</c>.</returns>
    private bool CheckWin(CellState player)
    {
        // Rows and columns
        for (int i = 0; i < 3; i++)
        {
            if ((board[i, 0] == player && board[i, 1] == player && board[i, 2] == player) ||
                (board[0, i] == player && board[1, i] == player && board[2, i] == player))
                return true;
        }

        // Diagonals
        if ((board[0, 0] == player && board[1, 1] == player && board[2, 2] == player) ||
            (board[0, 2] == player && board[1, 1] == player && board[2, 0] == player))
            return true;

        return false;
    }

    /// <summary>
    /// Determines whether every cell on the board is occupied, indicating a draw if no player has won.
    /// </summary>
    /// <returns><c>true</c> if the board is full (no empty cells); otherwise <c>false</c>.</returns>
    private bool IsBoardFull()
    {
        for (int r = 0; r < 3; r++)
            for (int c = 0; c < 3; c++)
                if (board[r, c] == CellState.Empty)
                    return false;
        return true;
    }

    // ====================================================================
    // UI Helpers
    // ====================================================================

    /// <summary>
    /// Returns the CSS class name for a board cell based on its current state.
    /// </summary>
    /// <param name="cell">The cell state (<see cref="CellState.Empty"/>, <see cref="CellState.X"/>, or <see cref="CellState.O"/>).</param>
    /// <returns>A CSS class string: <c>"tictactoe-cell-x"</c>, <c>"tictactoe-cell-o"</c>, or <c>"tictactoe-cell-empty"</c>.</returns>
    private string GetCellClass(CellState cell)
    {
        return cell switch
        {
            CellState.X => "tictactoe-cell-x",
            CellState.O => "tictactoe-cell-o",
            _ => "tictactoe-cell-empty"
        };
    }

    // ====================================================================
    // Game Control
    // ====================================================================

    /// <summary>
    /// Resets the game board and all game state to start a new game. Clears the board,
    /// sets it to the player's turn, and restores the default status message.
    /// Score counters (wins, losses, draws) are preserved across games.
    /// </summary>
    private void RestartGame()
    {
        board = new CellState[3, 3];
        gameOver = false;
        winner = CellState.Empty;
        isPlayerTurn = true;
        statusMessage = "Your turn — click a cell to place X";
    }
}

<style>
    .tictactoe-wrapper {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 1rem;
        padding: 1rem;
        user-select: none;
        font-family: 'Segoe UI', system-ui, sans-serif;
        position: relative;
    }

    .tictactoe-header {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.5rem;
        width: 100%;
        max-width: 320px;
        padding: 0.75rem 1rem;
        background: #1a1a2e;
        border-radius: 8px;
        border: 1px solid #16213e;
    }

    .tictactoe-score {
        display: flex;
        gap: 1rem;
        font-size: 1rem;
        font-weight: 600;
    }

    .score-label {
        color: #888;
    }

    .score-wins {
        color: #2196f3;
    }

    .score-losses {
        color: #ff9800;
    }

    .score-draws {
        color: #9e9e9e;
    }

    .tictactoe-status {
        color: #e0e0e0;
        font-size: 0.95rem;
        font-weight: 500;
    }

    .tictactoe-actions {
        display: flex;
        gap: 0.5rem;
    }

    .tictactoe-btn {
        padding: 0.4rem 0.9rem;
        border: 1px solid #333;
        border-radius: 6px;
        background: #16213e;
        color: #e0e0e0;
        font-size: 0.85rem;
        cursor: pointer;
        transition: background 0.15s, border-color 0.15s;
    }

    .tictactoe-btn:hover {
        background: #1a1a3e;
        border-color: #4caf50;
    }

    .tictactoe-btn-back {
        border-color: #533483;
    }

    .tictactoe-btn-back:hover {
        border-color: #7b2d8b;
        background: #2a1a3e;
    }

    .tictactoe-btn-primary {
        background: #4caf50;
        color: #fff;
        border-color: #4caf50;
        font-weight: 600;
        padding: 0.6rem 1.4rem;
        font-size: 1rem;
    }

    .tictactoe-btn-primary:hover {
        background: #43a047;
        border-color: #43a047;
    }

    .tictactoe-board {
        display: grid;
        grid-template-columns: repeat(3, 100px);
        grid-template-rows: repeat(3, 100px);
        gap: 4px;
        background: #0f0f23;
        border: 2px solid #1a1a3e;
        border-radius: 8px;
        padding: 4px;
    }

    .tictactoe-cell {
        width: 100px;
        height: 100px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 4px;
        cursor: pointer;
        transition: background 0.15s;
    }

    .tictactoe-cell-empty {
        background: #0f0f23;
    }

    .tictactoe-cell-empty:hover {
        background: #1a1a3e;
    }

    .tictactoe-cell-x {
        background: #0f0f23;
        cursor: default;
    }

    .tictactoe-cell-o {
        background: #0f0f23;
        cursor: default;
    }

    .tictactoe-x {
        font-size: 3.5rem;
        font-weight: 700;
        color: #2196f3;
        line-height: 1;
        text-shadow: 0 0 8px rgba(33, 150, 243, 0.5);
    }

    .tictactoe-o {
        font-size: 3.5rem;
        font-weight: 700;
        color: #ff9800;
        line-height: 1;
        text-shadow: 0 0 8px rgba(255, 152, 0, 0.5);
    }

    .tictactoe-overlay {
        position: absolute;
        inset: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        background: rgba(0, 0, 0, 0.75);
        backdrop-filter: blur(4px);
        z-index: 10;
        border-radius: 8px;
    }

    .tictactoe-overlay-content {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.8rem;
        padding: 2rem;
        background: #1a1a2e;
        border-radius: 12px;
        border: 1px solid #333;
        box-shadow: 0 8px 32px rgba(0, 0, 0, 0.4);
    }

    .tictactoe-overlay-title {
        font-size: 2rem;
        font-weight: 700;
        color: #e0e0e0;
        text-shadow: 0 0 10px rgba(76, 175, 80, 0.5);
    }
</style>