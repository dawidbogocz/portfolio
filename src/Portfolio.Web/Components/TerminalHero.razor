@inject IJSRuntime JS
@implements IDisposable

<div class="terminal-hero-wrapper">
    <div class="terminal-window">
        <div class="terminal-titlebar">
            <div class="terminal-dots">
                <span class="dot dot-red"></span>
                <span class="dot dot-yellow"></span>
                <span class="dot dot-green"></span>
            </div>
            <div class="terminal-title">dzeyd.dev -- bash</div>
            <div class="terminal-title-spacer"></div>
        </div>
        <div class="terminal-body" @ref="terminalBody">
            @foreach (var line in displayedLines)
            {
                <div class="terminal-line">@line</div>
            }
            @if (typingLine != null)
            {
                <div class="terminal-line typing-line">@typingLine<span class="cursor-solid">|</span></div>
            }
            @if (showPrompt)
            {
                <div class="terminal-line prompt-line">
                    <span class="prompt-text">dzeyd&#64;portfolio:~$</span>
                    @if (!string.IsNullOrEmpty(whoamiTyped))
                    {
                        <span class="whoami-command">@whoamiTyped</span>
                    }
                    @if (!showWhoamiOutput)
                    {
                        <span class="cursor-blink">|</span>
                    }
                </div>
            }
            @if (showWhoamiOutput)
            {
                <div class="terminal-line whoami-output">
                    <div class="whoami-table">
                        <div class="whoami-row">
                            <span class="whoami-label">name:</span>
                            <span class="whoami-value">Dawid Bogocz</span>
                        </div>
                        <div class="whoami-row">
                            <span class="whoami-label">alias:</span>
                            <span class="whoami-value">dzeyd</span>
                        </div>
                        <div class="whoami-row">
                            <span class="whoami-label">location:</span>
                            <span class="whoami-value">Wieluń, Poland</span>
                        </div>
                        <div class="whoami-row">
                            <span class="whoami-label">role:</span>
                            <span class="whoami-value">MES Administrator // Game &amp; App Dev // AI Dabbler</span>
                        </div>
                    </div>
                </div>
                <div class="terminal-line prompt-line">
                    <span class="prompt-text">dzeyd&#64;portfolio:~$</span>
                    <span class="cursor-blink">|</span>
                </div>
            }
        </div>
    </div>
</div>

<style>
    .terminal-hero-wrapper {
        min-height: calc(100vh - 56px);
        width: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        background: #0a0a14;
        padding: 20px;
        box-sizing: border-box;
    }

    .terminal-window {
        width: 100%;
        max-width: 820px;
        border-radius: 8px;
        overflow: hidden;
        box-shadow: 0 8px 32px rgba(0, 0, 0, 0.6), 0 0 0 1px rgba(0, 255, 65, 0.12);
        background: #0d0d1a;
        font-family: 'Courier New', 'Consolas', 'Monaco', 'Fira Code', monospace;
        font-size: 15px;
        line-height: 1.5;
    }

    .terminal-titlebar {
        display: flex;
        align-items: center;
        padding: 10px 16px;
        background: #1a1a2e;
        border-bottom: 1px solid #2a2a3e;
        user-select: none;
    }

    .terminal-dots {
        display: flex;
        gap: 8px;
        flex-shrink: 0;
    }

    .dot {
        width: 12px;
        height: 12px;
        border-radius: 50%;
        display: inline-block;
    }

    .dot-red { background: #ff5f56; }
    .dot-yellow { background: #ffbd2e; }
    .dot-green { background: #27c93f; }

    .terminal-title {
        flex: 1;
        text-align: center;
        color: #8888aa;
        font-size: 13px;
        font-weight: 600;
        letter-spacing: 0.3px;
    }

    .terminal-title-spacer {
        width: 52px;
        flex-shrink: 0;
    }

    .terminal-body {
        padding: 24px 24px 32px;
        min-height: 320px;
        color: #00ff41;
        background: #0d0d1a;
        overflow-x: auto;
        text-align: left;
    }

    .terminal-line {
        white-space: pre-wrap;
        word-break: break-word;
        min-height: 1.5em;
    }

    .typing-line {
        display: inline;
    }

    .cursor-solid {
        color: #00ff41;
        animation: none;
    }

    .cursor-blink {
        color: #00ff41;
        animation: blink 0.8s step-end infinite;
    }

    .prompt-text {
        color: #00ff41;
    }

    .whoami-command {
        color: #ffffff;
        font-weight: normal;
    }

    .whoami-output {
        padding-top: 8px;
        padding-bottom: 8px;
    }

    .whoami-table {
        display: flex;
        flex-direction: column;
        gap: 4px;
    }

    .whoami-row {
        display: flex;
        gap: 12px;
        align-items: baseline;
    }

    .whoami-label {
        color: #56b6c2;
        min-width: 80px;
        flex-shrink: 0;
    }

    .whoami-value {
        color: #e5c07b;
    }

    @@keyframes blink {
        0%, 100% { opacity: 1; }
        50% { opacity: 0; }
    }

    @@media (max-width: 600px) {
        .terminal-hero-wrapper {
            padding: 12px;
        }

        .terminal-body {
            padding: 16px 16px 24px;
            font-size: 13px;
        }

        .terminal-title {
            font-size: 11px;
        }

        .whoami-label {
            min-width: 60px;
        }
    }
</style>

@code {
    // === FIELDS & PROPERTIES ===

    /// <summary>
    /// Reference to the terminal body DOM element, used for scrolling.
    /// </summary>
    private ElementReference terminalBody;

    /// <summary>
    /// Collection of completely typed-out lines displayed in the terminal.
    /// </summary>
    private List<string> displayedLines = new();

    /// <summary>
    /// The currently-being-typed line shown temporarily during the typing effect.
    /// Null when no line is actively being typed.
    /// </summary>
    private string? typingLine;

    /// <summary>
    /// Whether the terminal prompt (dzeyd@portfolio:~$) is visible.
    /// </summary>
    private bool showPrompt;

    /// <summary>
    /// The portion of the "whoami" command that has been typed so far on the prompt line.
    /// </summary>
    private string whoamiTyped = "";

    /// <summary>
    /// Whether the whoami command output table should be displayed.
    /// </summary>
    private bool showWhoamiOutput;

    // === BOOT MESSAGES ===

    /// <summary>
    /// The sequence of system boot messages displayed one by one with a typing effect.
    /// </summary>
    private readonly string[] bootMessages = new[]
    {
        "[system] boot sequence initiated...",
        "[system] loading portfolio modules...",
        "[system] authentication: dawid bogocz / dzeyd",
        "[ok] system ready."
    };

    // === LIFECYCLE STATE ===

    /// <summary>
    /// Cancellation token source used to abort async operations when the component is disposed.
    /// </summary>
    private CancellationTokenSource? _cts;

    // === LIFECYCLE METHODS ===

    /// <summary>
    /// Initializes the component by running the terminal boot sequence:
    /// types out boot messages, shows the prompt, types the "whoami" command,
    /// then displays the whoami identity output.
    /// </summary>
    protected override async Task OnInitializedAsync()
    {
        _cts = new CancellationTokenSource();
        var token = _cts.Token;

        try
        {
            // Type out each boot message with character-by-character typing effect
            foreach (var message in bootMessages)
            {
                token.ThrowIfCancellationRequested();
                await TypeLine(message, token);

                token.ThrowIfCancellationRequested();
                await Task.Delay(400, token);
            }

            token.ThrowIfCancellationRequested();

            // Show the prompt with blinking cursor
            showPrompt = true;
            StateHasChanged();

            // Pause before typing the whoami command
            await Task.Delay(800, token);

            // Type " whoami" character by character on the prompt line
            string whoamiText = " whoami";
            for (int i = 0; i < whoamiText.Length; i++)
            {
                token.ThrowIfCancellationRequested();
                whoamiTyped = whoamiText[..(i + 1)];
                StateHasChanged();
                await Task.Delay(50, token);
            }

            // Pause before showing output
            await Task.Delay(500, token);

            // Show whoami output
            showWhoamiOutput = true;
            StateHasChanged();

            // Scroll to bottom
            await ScrollToBottom();
        }
        catch (OperationCanceledException)
        {
            // Component disposed, gracefully ignore
        }
    }

    // === HELPER METHODS ===

    /// <summary>
    /// Types out the given text character by character into the typing line,
    /// then moves it to the displayed lines list once complete.
    /// </summary>
    /// <param name="text">The text to type out.</param>
    /// <param name="token">Cancellation token to abort the typing effect.</param>
    private async Task TypeLine(string text, CancellationToken token)
    {
        typingLine = "";
        StateHasChanged();

        for (int i = 0; i < text.Length; i++)
        {
            token.ThrowIfCancellationRequested();
            typingLine = text[..(i + 1)];
            StateHasChanged();
            await Task.Delay(30, token);
        }

        // Move completed line to the displayed list
        displayedLines.Add(text);
        typingLine = null;
        StateHasChanged();

        await ScrollToBottom();
    }

    /// <summary>
    /// Scrolls the terminal body element to the bottom using JavaScript interop.
    /// Silently ignores failures (e.g. if the JS runtime is unavailable).
    /// </summary>
    private async Task ScrollToBottom()
    {
        try
        {
            await JS.InvokeVoidAsync("portfolio.scrollElementToBottom", terminalBody);
        }
        catch
        {
            // Ignore if JS interop fails
        }
    }

    // === DISPOSAL ===

    /// <summary>
    /// Cancels any ongoing async operations and releases the cancellation token source.
    /// Called when the component is removed from the render tree.
    /// </summary>
    public void Dispose()
    {
        _cts?.Cancel();
        _cts?.Dispose();
    }
}