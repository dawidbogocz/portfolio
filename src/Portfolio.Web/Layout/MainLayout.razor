@inherits LayoutComponentBase
@implements IDisposable
@inject ThemeService ThemeService
@inject IJSRuntime JS

<div class="root-layout">
    <Navigation />
    <main>
        <section class="section hero-section" id="home">
            <Hero />
        </section>
        <section class="section reveal" id="about">
            <AboutSection />
        </section>
        <section class="section reveal" id="experience">
            <ExperienceSection />
        </section>
        <section class="section reveal" id="projects">
            <ProjectsSection />
        </section>
        <section class="section reveal" id="games">
            <GamesSection />
        </section>
        <section class="section reveal" id="contact">
            <ContactSection />
        </section>
        <footer class="footer">
            <p>&copy; @DateTime.Now.Year - Dawid Bogocz. Built with Blazor &amp; .NET</p>
        </footer>
    </main>
    <button id="back-to-top" @onclick='() => ScrollTo("home")'>&#8593;</button>
</div>

@code {
    protected override async Task OnInitializedAsync()
    {
        ThemeService.ThemeChanged += OnThemeChanged;
        var savedTheme = await JS.InvokeAsync<string>("portfolio.loadTheme");
        if (!string.IsNullOrEmpty(savedTheme))
            ThemeService.SetTheme(savedTheme);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JS.InvokeVoidAsync("portfolio.applyTheme", ThemeService.CurrentTheme);
            await JS.InvokeVoidAsync("portfolio.initScrollspy");
            await JS.InvokeVoidAsync("portfolio.initScrollReveal");
            await JS.InvokeVoidAsync("portfolio.initBackToTop");
        }
    }

    private async void OnThemeChanged()
    {
        await JS.InvokeVoidAsync("portfolio.applyTheme", ThemeService.CurrentTheme);
        StateHasChanged();
    }

    private async Task ScrollTo(string id)
    {
        await JS.InvokeVoidAsync("portfolio.scrollTo", id);
    }

    public void Dispose()
    {
        ThemeService.ThemeChanged -= OnThemeChanged;
    }
}